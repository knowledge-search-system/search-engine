SEARCH_ENGINE_ELASTICSEARCH_ADDRESSES=http://elasticsearch:9200
SEARCH_ENGINE_ELASTICSEARCH_USERNAME=
SEARCH_ENGINE_ELASTICSEARCH_PASSWORD=

SEARCH_ENGINE_LOG_LEVEL=info
